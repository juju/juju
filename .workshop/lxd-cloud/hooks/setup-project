#!/bin/bash
set -eu

CERT_DIR="/home/workshop/.config/lxc"
JUJU_DATA="/home/workshop/.local/share/juju"

# Generate a client certificate for authenticating with LXD over HTTPS.
mkdir -p "${CERT_DIR}"

if [ ! -f "${CERT_DIR}/client.crt" ]; then
  openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:secp384r1 \
    -sha384 -keyout "${CERT_DIR}/client.key" \
    -out "${CERT_DIR}/client.crt" -nodes -days 3650 \
    -subj "/CN=workshop" 2>/dev/null
  chmod 600 "${CERT_DIR}/client.key"
fi

# Pre-create juju data directory.
mkdir -p "${JUJU_DATA}"

# Discover the host LXD address via the container's default gateway.
# The host must have: lxc config set core.https_address "[::]:8443"
HOST_IP=$(ip route show default | awk '{print $3}')
if [ -z "${HOST_IP}" ]; then
  echo "ERROR: Cannot determine host IP from default route."
  exit 1
fi

LXD_ENDPOINT="https://${HOST_IP}:8443"

# Fetch the LXD server certificate over TLS (does not require trust).
SERVER_CERT=$(echo | openssl s_client -connect "${HOST_IP}:8443" 2>/dev/null | openssl x509 2>/dev/null || true)
if [ -z "${SERVER_CERT}" ]; then
  echo "ERROR: Cannot reach LXD at ${LXD_ENDPOINT}."
  echo "Ensure LXD is configured: lxc config set core.https_address \"[::]:8443\""
  exit 1
fi

# Write cloud config with discovered host address.
cat > "${JUJU_DATA}/clouds.yaml" <<EOF
clouds:
  lxd:
    type: lxd
    endpoint: ${LXD_ENDPOINT}
EOF

# Write credentials referencing the client cert and pinning the server cert.
cat > "${JUJU_DATA}/credentials.yaml" <<EOF
credentials:
  lxd:
    workshop:
      auth-type: certificate
      client-cert: |
$(sed 's/^/        /' "${CERT_DIR}/client.crt")
      client-key: |
$(sed 's/^/        /' "${CERT_DIR}/client.key")
      server-cert: |
$(echo "${SERVER_CERT}" | sed 's/^/        /')
EOF
chmod 600 "${JUJU_DATA}/credentials.yaml"

echo "Credentials configured for LXD at ${LXD_ENDPOINT}"
