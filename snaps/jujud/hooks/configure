#!/bin/sh

# jujud configure hook --- applies snap-set runtime overrides to runtime.conf.
#
# Only logging-override is supported in this Phase 1 slice.
# When runtime.conf has not been staged yet the value is deferred and is
# applied after jujud.init creates the base file.
# When the daemon is active and the applied value changes, the service is
# bounced so workers pick up the new startup value through a clean restart.

set -e

RUNTIME_CONF="$SNAP_DATA/agents/controller-0/runtime.conf"
SNAP_INIT_DIR="$SNAP_COMMON/.snap-init"
PREV_VAL_FILE="$SNAP_INIT_DIR/.last-logging-override"

(
    echo "configure hook: starting"

    requested="$(snapctl get logging-override)"

    # Normalise snapctl "null" / empty to empty string.
    if [ -z "$requested" ] || [ "$requested" = "null" ]; then
        requested=""
    fi

    # Read the previously applied value so we can avoid unnecessary bounces.
    prev_applied=""
    if [ -f "$PREV_VAL_FILE" ]; then
        prev_applied="$(cat "$PREV_VAL_FILE")"
    fi

    if [ "$requested" = "$prev_applied" ]; then
        echo "configure hook: logging-override unchanged, skipping apply"
        exit 0
    fi

    if [ -f "$RUNTIME_CONF" ]; then
        # Apply via the typed helper. This mutates only logging-override
        # and atomically rewrites runtime.conf. All other fields are
        # preserved unchanged.
        "$SNAP/bin/jujud" controller-config \
            --runtime-config-path "$RUNTIME_CONF" \
            --snap-common "$SNAP_COMMON" \
            --logging-override "$requested"

        echo "configure hook: applied logging-override"

        # Persist the applied value for future comparison.
        umask 022
        mkdir -p "$SNAP_INIT_DIR"
        printf '%s\n' "$requested" > "$PREV_VAL_FILE"

        # Bounce the daemon when active so workers pick up the new value.
        if snapctl services jujud.jujud | grep -q 'active'; then
            echo "configure hook: bouncing jujud daemon"
            snapctl stop jujud.jujud
            snapctl start jujud.jujud
        fi
    else
        # runtime.conf does not exist yet. Defer the value via the typed
        # helper so it is applied after jujud.init stages the base file.
        "$SNAP/bin/jujud" controller-config \
            --runtime-config-path "$RUNTIME_CONF" \
            --snap-common "$SNAP_COMMON" \
            --logging-override "$requested"

        echo "configure hook: deferred logging-override (runtime.conf not yet staged)"
    fi

    echo "configure hook: done"
) >> "$SNAP_COMMON/hook.log"
