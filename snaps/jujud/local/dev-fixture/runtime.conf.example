# Minimum controller runtime fixture for local snapd bring-up (JUJU-10105).
# This is a developer staging aid, not snap runtime content. Do not ship
# real private key material here. Source TLS material from bootstrap output
# or a purpose-built test fixture.
# All values below are valid dummy placeholders. Replace them with real
# values before using in a non-test deployment.
controller-id: "0"
controller-uuid: "00000000-0000-0000-0000-000000000000"
controller-model-uuid: "00000000-0000-0000-0000-000000000000"
data-dir: /var/snap/jujud/common/var/lib/juju
log-dir: /var/snap/jujud/common/var/log/juju
api-port: 17070
agent-password: replace-with-real-agent-password
ca-cert: |
  replace-with-real-ca-cert
ca-private-key: |
  replace-with-real-ca-private-key
controller-cert: |
  replace-with-real-controller-cert
controller-private-key: |
  replace-with-real-controller-private-key
# api-addresses entries, when present, must be non-empty valid addresses.
# api-addresses:
#   - 10.0.0.1:17070
